# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN

# Optional: Gemini API key for the discovery agent
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY

# Path to SQLite DB (default: ./data/radar.db)
DB_PATH=./data/radar.db

# Path to data files (default: ./data)
DATA_DIR=./data

# Default timezone for new users (default: Asia/Tokyo)
DEFAULT_TIMEZONE=US/Chicago

# Optional: Slack incoming webhook URL — only used if you want server-side Slack delivery.
# Most users will paste their own webhook into the Telegram bot via /set_slack
SLACK_WEBHOOK_URL=
